{
  "name": "api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["api"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/.playwright/apps/api-e2e/test-output",
        "{workspaceRoot}/dist/.playwright/apps/api-e2e/playwright-report"
      ],
      "options": {
        "cwd": "apps/api-e2e",
        "command": "playwright test"
      },
      "dependsOn": ["api:build"]
    }
  }
}
